# Supabase (Project Settings -> API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Edge Function URL (optional if VITE_SUPABASE_URL is set — defaults to {url}/functions/v1/search-tracks)
VITE_SUPABASE_FUNCTION_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/search-tracks
