# Supabase (Project Settings -> API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Edge Function URL after deploy:
# supabase functions deploy search-tracks --no-verify-jwt
# Then: https://YOUR_PROJECT_REF.supabase.co/functions/v1/search-tracks
VITE_SEARCH_FUNCTION_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/search-tracks
